rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras temporárias de desenvolvimento (liberadas) para o app funcionar
    // enquanto o modelo de permissões (admin/funcionário) é consolidado.
    match /pontos/{document=**} {
      allow read, write: if true;
    }
    match /solicitacoes_correcao/{document=**} {
      allow read, write: if true;
    }
    match /seguranca_usuarios/{document=**} {
      allow read, write: if true;
    }
    match /fechamentos/{document=**} {
      allow read, write: if true;
    }
  }
}
